# NeonShare Environment Configuration
# Copy this file to .env and replace with your actual values

# Server port (default 3000)
PORT=3000

# Groq API Key for AI features (optional)
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (optional, default: mixtral-8x7b-32768)
GROQ_MODEL_NAME=mixtral-8x7b-32768

# FFmpeg audio codec (optional, default: libmp3lame for MP3)
CONVERT_CODEC=libmp3lame

# ========================================
# SUPPORTED PLATFORMS (via yt-dlp)
# ========================================
# YouTube, TikTok, Instagram, Pinterest, Facebook, 
# Reddit, Twitter/X, Snapchat, Threads, Bluesky,
# and 1000+ other video/media platforms
#
# REQUIREMENTS:
# - yt-dlp: pip install yt-dlp (for video downloading)
# - ffmpeg: included via ffmpeg-static (for audio conversion)
# ========================================
